        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Review Cart"
          },
          {
            "type": "TextCaption",
            "text": "${data.cart_count_label}"
          },
          {
            "type": "Form",
            "name": "cart_review_form",
            "init-values": {
              "cart_review_selection": "${data.cart_review_selection}"
            },
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "cart_review_selection",
                "label": "Items in your cart",
                "required": false,
                "enabled": false,
                "media-size": "regular",
                "data-source": "${data.cart_review_items}",
                "visible": "${data.cart_has_items}"
              }
            ]
          },
          {
            "type": "TextHeading",
            "text": "${data.cart_total_label}"
          },
          {
            "type": "TextCaption",
            "text": "Use the back arrow to add another item."
          },
          {
            "type": "Footer",
            "label": "Proceed to Checkout",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "intent": "checkout",
                "cart_items": "${data.cart_items}"
              }
            }
          }
        ]
      }
    }
