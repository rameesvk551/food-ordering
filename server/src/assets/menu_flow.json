                "type": "TextInput",
                "name": "district",
                "label": "District",
                "required": false
              },
              {
                "type": "TextInput",
                "name": "pincode",
                "label": "Pincode",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "TextArea",
                "name": "location_note",
                "label": "Location / landmark / map link (optional)"
              },
              {
                "type": "Footer",
                "label": "Review Order",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "intent": "submit_new_address",
                    "cart_items": "${data.cart_items}",
                    "name": "${form.name}",
                    "phone_number": "${form.phone_number}",
                    "flat": "${form.flat}",
                    "address": "${form.address}",
                    "city": "${form.city}",
                    "pincode": "${form.pincode}",
                    "district": "${form.district}",
                    "location_note": "${form.location_note}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "CHECKOUT_CONFIRM",
      "title": "Confirm Order",
      "terminal": true,
      "success": true,
      "data": {
        "cart_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "line_id": { "type": "string" },
              "product_id": { "type": "string" },
              "name": { "type": "string" },
              "portion_id": { "type": "string" },
              "portion_label": { "type": "string" },
              "quantity": { "type": "string" },
              "unit_price": { "type": "string" },
              "notes": { "type": "string" }
            }
          },
          "__example__": []
        },
        "cart_summary": {
          "type": "string",
          "__example__": "1. Margherita\nSize: Regular | Qty: 2 | Total: INR 598"
        },
        "cart_total_label": {
          "type": "string",
          "__example__": "Total • INR 598"
        },
        "delivery_address": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "name": { "type": "string" },
            "phoneNumber": { "type": "string" },
            "flat": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "pincode": { "type": "string" },
            "district": { "type": "string" },
            "latitude": { "type": "string" },
            "longitude": { "type": "string" },
            "location_note": { "type": "string" }
          },
          "__example__": {
            "label": "Home",
            "name": "Ravi Kumar",
            "phoneNumber": "9876543210",
            "flat": "12B",
            "address": "Brigade Road",
            "city": "Bengaluru",
            "pincode": "560001",
            "district": "Bengaluru Urban",
            "latitude": "12.9716",
            "longitude": "77.5946",
            "location_note": "Near metro station"
          }
        },
        "delivery_address_summary": {
          "type": "string",
          "__example__": "Name: Ravi Kumar\nPhone: 9876543210\nFlat: 12B\nAddress: Brigade Road\nBengaluru - 560001"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Confirm Order"
          },
          {
            "type": "TextCaption",
            "text": "${data.cart_total_label}"
          },
          {
            "type": "TextBody",
            "markdown": true,
            "text": "**Delivery address**\n${data.delivery_address_summary}"
          },
          {
            "type": "TextBody",
            "markdown": true,
            "text": "**Items**\n${data.cart_summary}"
          },
          {
            "type": "Footer",
            "label": "Place Order",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "intent": "checkout",
                "cart_items": "${data.cart_items}",
                "delivery_address": "${data.delivery_address}"
              }
            }
          }
        ]
      }
    }
  ]
}
